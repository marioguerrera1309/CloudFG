<Window x:Class="CloudFG.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CloudFG"
        mc:Ignorable="d"
        Title="CloudFG" Height="450" Width="800"
        Icon="CloudFGIcon.ico">
    <Grid Margin="20">
        <TabControl Background="Transparent" BorderThickness="0">
            <TabItem Header="Login" Padding="10,5">
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="Username" Margin="0,0,0,5"/>
                    <TextBox Name="txtUserLogin" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="Password" Margin="0,0,0,5"/>
                    <PasswordBox Name="txtPassLogin" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,20"/>
                    <Button Content="Accedi" Click="BtnLoginClick" Height="35" Background="LightBlue" FontWeight="Bold"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Registrati" Padding="10,5">
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="Username" Margin="0,0,0,5"/>
                    <TextBox Name="txtUserReg" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Password" Margin="0,0,0,5"/>
                    <PasswordBox Name="txtPassReg" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Conferma Password" Margin="0,0,0,5"/>
                    <PasswordBox Name="txtPassConfirm" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"/>
                    <Button Content="Crea Account" Click="BtnRegisterClick" Height="35" Background="LightGreen" FontWeight="Bold"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
