<Window x:Class="CloudFG.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CloudFG"
        mc:Ignorable="d"
        Title="Risultati ricerca" Height="450" Width="800"
        WindowStartupLocation="Manual"
        Icon="CloudFGIcon.ico">
    <ScrollViewer Margin="10" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <ItemsControl Name="lstResults" HorizontalContentAlignment="Stretch">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📖 " VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                <TextBlock Text=" - "/>
                                <TextBlock Text="{Binding Author}" FontStyle="Italic"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding FilePath}" Margin="10,0" VerticalAlignment="Center" Foreground="Gray"/>
                            <TextBlock Grid.Column="3" Text="{Binding Date}" Margin="10,0" VerticalAlignment="Center" Foreground="Gray"/>
                            <Button Grid.Column="4" Content="Apri" Click="BtnResultClick" Width="60"/>
                            <Button Grid.Column="5" Content="Visualizza analisi" Click="BtnViewAnaliticsClick" Width="100" Margin="5,0"/>
                            <Button Grid.Column="6" Content="Elimina" Click="BtnDeleteResultClick" Width="60" Background="Salmon"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Window>