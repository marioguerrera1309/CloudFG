<Window x:Class="LibgenUI.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibgenUI"
        mc:Ignorable="d"
        Title="Risultati ricerca" Height="450" Width="800"
        WindowStartupLocation="Manual"
        Icon="LibgenIcon.ico">
    <ScrollViewer Margin="10">
        <ItemsControl Name="lstResults">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Margin="0,5" Padding="10" Click="BtnResultClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📖 "/>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                            <TextBlock Text=" - "/>
                            <TextBlock Text="{Binding Author}" FontStyle="Italic"/>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Window>
