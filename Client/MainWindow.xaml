<Window x:Class="Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Name="lblFileName" Text="Nessun file selezionato" Margin="0,0,0,10" TextTrimming="CharacterEllipsis"/>
        <Button Name="btnSelect" Content="Seleziona e Invia File" Click="BtnSelect_Click" Height="35" Margin="0,0,0,10"/>
        <ProgressBar Name="uploadProgressBar" Height="15" Minimum="0" Maximum="100" Margin="0,0,0,5" Visibility="Hidden"/>
        <TextBlock Name="lblStatus" Text="Pronto" Foreground="Gray" HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
